/* =============================================
   PUMPING LEMMA VISUALIZER — STYLESHEET
   style.css
   ============================================= */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ─── DESIGN TOKENS ─── */
:root {
  --ink: #0a0a0a;
  --paper: #f5f2eb;
  --paper2: #ede9df;
  --paper3: #e4dfd3;
  --red: #c0392b;
  --red-light: #e8d5d3;
  --blue: #1a3a5c;
  --gold: #b8860b;
  --mono: 'IBM Plex Mono', monospace;
  --serif: 'Playfair Display', serif;
  --sans: 'IBM Plex Sans', sans-serif;
  --border: 1.5px solid var(--ink);
  --border-thin: 1px solid rgba(10, 10, 10, 0.18);
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--paper);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 15px;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ─── NOISE TEXTURE OVERLAY ─── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px;
}

.page-wrap {
  position: relative;
  z-index: 1;
}

/* ─── SCROLL PROGRESS BAR ─── */
.progress-bar {
  height: 3px;
  background: var(--red);
  width: 0;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 200;
  transition: width 0.1s;
}

/* ─── NAVIGATION ─── */
nav {
  border-bottom: var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 3rem;
  height: 56px;
  background: var(--paper);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-logo {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
}

.nav-links {
  display: flex;
  gap: 0;
  list-style: none;
}

.nav-links a {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding: 0 1.2rem;
  height: 56px;
  display: flex;
  align-items: center;
  border-left: var(--border-thin);
  transition: background 0.15s;
}

.nav-links a:hover {
  background: var(--paper2);
}

@media (max-width: 640px) {
  nav { padding: 0 1rem; }
  .nav-links { display: none; }
}

/* ─── HERO ─── */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - 56px);
  border-bottom: var(--border);
}

@media (max-width: 780px) {
  .hero { grid-template-columns: 1fr; }
}

.hero-left {
  padding: 5rem 4rem 4rem;
  border-right: var(--border);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

@media (max-width: 780px) {
  .hero-left {
    padding: 3rem 1.5rem 2rem;
    border-right: none;
    border-bottom: var(--border);
  }
}

.eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.eyebrow::before {
  content: '';
  display: inline-block;
  width: 28px;
  height: 1.5px;
  background: var(--red);
}

.hero-h1 {
  font-family: var(--serif);
  font-size: clamp(2.8rem, 5vw, 4.5rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 1.75rem;
}

.hero-h1 em {
  font-style: italic;
  color: var(--red);
}

.hero-desc {
  font-size: 14px;
  line-height: 1.8;
  color: rgba(10, 10, 10, 0.6);
  max-width: 380px;
  margin-bottom: 2.5rem;
}

.cta-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

/* ─── BUTTONS ─── */
.btn-primary {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  border: none;
  padding: 14px 28px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: background 0.2s;
}

.btn-primary:hover {
  background: var(--red);
}

.btn-secondary {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: transparent;
  color: var(--ink);
  border: var(--border);
  padding: 14px 28px;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: background 0.2s;
}

.btn-secondary:hover {
  background: var(--paper2);
}

/* ─── HERO RIGHT / FORMULA ─── */
.hero-right {
  background: var(--paper2);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 3rem;
}

.formula-display {
  border: var(--border);
  background: var(--paper);
  padding: 2rem 2.5rem;
}

.formula-tag {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.4);
  border-bottom: var(--border-thin);
  padding-bottom: 0.75rem;
  margin-bottom: 1.25rem;
}

.formula-line {
  font-family: var(--mono);
  font-size: 13px;
  line-height: 2.2;
  color: var(--ink);
}

.formula-line .kw { color: var(--red); font-weight: 600; }
.formula-line .sym { color: var(--blue); }

.formula-line .cond {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--paper2);
  border-left: 3px solid var(--ink);
  padding: 1px 10px 1px 8px;
  margin: 2px 0;
}

/* ─── HERO STATS ─── */
.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 2rem;
  border: var(--border);
  border-top: none;
}

.stat {
  padding: 1.25rem;
  border-right: var(--border);
  background: var(--paper);
}

.stat:last-child { border-right: none; }

.stat-num {
  font-family: var(--serif);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 4px;
  color: var(--ink);
}

.stat-lbl {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.45);
}

/* ─── SECTION CHROME ─── */
.tool-wrap { padding: 0; }

.section-header {
  display: flex;
  align-items: stretch;
  border-bottom: var(--border);
}

.section-num {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  color: var(--paper);
  background: var(--ink);
  padding: 1rem 1.5rem;
  display: flex;
  align-items: center;
  min-width: 60px;
  justify-content: center;
  border-right: var(--border);
  writing-mode: vertical-lr;
  text-orientation: mixed;
  transform: rotate(180deg);
  white-space: nowrap;
}

.section-title-block {
  padding: 1.5rem 2.5rem;
  flex: 1;
}

.section-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 4px;
}

.section-h {
  font-family: var(--serif);
  font-size: 1.6rem;
  font-weight: 700;
  line-height: 1.2;
}

.section-body { padding: 2.5rem; }

@media (max-width: 640px) {
  .section-body { padding: 1.5rem; }
  .section-title-block { padding: 1.5rem; }
}

/* ─── CONFIGURE PANEL ─── */
#config { border-top: var(--border); border-bottom: var(--border); }

.config-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border: var(--border);
}

@media (max-width: 600px) {
  .config-grid { grid-template-columns: 1fr; }
}

.config-cell {
  padding: 1.5rem;
  border-right: var(--border);
  border-bottom: var(--border-thin);
}

.config-cell:nth-child(2n) { border-right: none; }
.config-cell.full { grid-column: 1 / -1; border-right: none; }
.config-cell:last-child { border-bottom: none; }

.cfg-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.45);
  margin-bottom: 8px;
}

.cfg-select,
.cfg-input {
  width: 100%;
  background: var(--paper);
  border: var(--border);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 13px;
  padding: 10px 12px;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  transition: border-color 0.15s;
}

.cfg-select:focus,
.cfg-input:focus {
  border-color: var(--red);
}

.cfg-select option { background: var(--paper); }

.run-row {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 2rem;
}

.run-btn {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  border: var(--border);
  padding: 16px 36px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: background 0.18s;
  flex-shrink: 0;
}

.run-btn:hover {
  background: var(--red);
  border-color: var(--red);
}

.run-hint {
  font-family: var(--mono);
  font-size: 10px;
  color: rgba(10, 10, 10, 0.35);
  padding-left: 1.5rem;
  letter-spacing: 0.05em;
}

/* ─── VISUALIZATION PANEL ─── */
#viz-panel { display: none; border-bottom: var(--border); }
#viz-panel.active { display: block; }

.char-section-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.4);
  margin-bottom: 12px;
}

.char-track {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  align-items: flex-end;
  margin-bottom: 1rem;
}

.char-cell {
  position: relative;
  width: 46px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 24px;
  font-weight: 500;
  border: 1.5px solid transparent;
  flex-shrink: 0;
  transition: transform 0.25s, background 0.3s;
}

.char-cell.cx { background: #ddeeff; border-color: #4a80b0; color: #1a3a5c; }
.char-cell.cy {
  background: #fff3db;
  border-color: #c48a00;
  color: #7a5500;
  animation: floatY 1.8s ease-in-out infinite;
}
.char-cell.cz { background: #dff3e4; border-color: #3a8a50; color: #1a5a30; }
.char-cell.ce { background: #fde8e8; border-color: #c0392b; color: #7a1515; }
.char-cell.ceps {
  background: var(--paper2);
  border-color: rgba(10, 10, 10, 0.15);
  color: rgba(10, 10, 10, 0.35);
  font-size: 12px;
}

@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-5px); }
}

.seg-tag {
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.seg-tag.tx { color: #1a3a5c; }
.seg-tag.ty { color: #7a5500; }
.seg-tag.tz { color: #1a5a30; }

/* ─── CONSTRAINTS ─── */
.constraint-strip {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin: 1rem 0 2rem;
}

.ctag {
  font-family: var(--mono);
  font-size: 11px;
  padding: 5px 14px;
  border: 1.5px solid;
}

.ctag.ok     { border-color: #3a8a50; color: #1a5a30; background: #dff3e4; }
.ctag.fail   { border-color: var(--red); color: var(--red); background: var(--red-light); }
.ctag.neutral { border-color: rgba(10,10,10,0.2); color: rgba(10,10,10,0.5); background: var(--paper2); }

/* ─── PUMP CONTROLS ─── */
.pump-strip {
  background: var(--paper2);
  border: var(--border);
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.pump-label {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  color: rgba(10, 10, 10, 0.5);
  white-space: nowrap;
}

input[type="range"] {
  flex: 1;
  min-width: 120px;
  max-width: 260px;
  accent-color: var(--ink);
}

.pump-val {
  font-family: var(--serif);
  font-size: 2rem;
  font-weight: 700;
  color: var(--ink);
  min-width: 32px;
  line-height: 1;
}

/* ─── MEMBERSHIP BADGE ─── */
.membership-bar {
  margin-top: 1rem;
  padding: 14px 20px;
  font-family: var(--mono);
  font-size: 13px;
  border: 1.5px solid;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: background 0.3s, border-color 0.3s;
}

.membership-bar.mem-in  { border-color: #3a8a50; background: #dff3e4; color: #1a5a30; }
.membership-bar.mem-out { border-color: var(--red); background: var(--red-light); color: var(--red); }
.mem-icon { font-size: 18px; }

/* ─── LEGEND ─── */
.legend-row {
  display: flex;
  gap: 0;
  border: var(--border);
  margin-bottom: 2rem;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  border-right: var(--border-thin);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
}

.legend-item:last-child { border-right: none; }

.lsq {
  width: 14px;
  height: 14px;
  border: 1.5px solid;
  flex-shrink: 0;
}

.lsq.lx { background: #ddeeff; border-color: #4a80b0; }
.lsq.ly { background: #fff3db; border-color: #c48a00; }
.lsq.lz { background: #dff3e4; border-color: #3a8a50; }
.lsq.le { background: #fde8e8; border-color: var(--red); }

/* ─── PROOF PANEL ─── */
#proof-panel { display: none; border-bottom: var(--border); }
#proof-panel.active { display: block; }

.proof-grid {
  display: grid;
  grid-template-columns: 48px 1fr;
  border: var(--border);
  margin-bottom: 2rem;
}

.proof-step-num {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  background: var(--ink);
  color: var(--paper);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: var(--border-thin);
}

.proof-step-body {
  padding: 1rem 1.5rem;
  border-bottom: var(--border-thin);
  border-left: var(--border);
  font-size: 13px;
  line-height: 1.75;
  color: rgba(10, 10, 10, 0.75);
}

.proof-step-body strong { color: var(--ink); font-weight: 500; }
.proof-step-body:last-child { border-bottom: none; }
.proof-step-num:last-of-type { border-bottom: none; }

.proof-step-body code {
  font-family: var(--mono);
  font-size: 12px;
  background: var(--paper2);
  border: var(--border-thin);
  padding: 1px 6px;
}

/* ─── ACCORDION ─── */
.accordion { border: var(--border); }
.acc-item { border-bottom: var(--border-thin); }
.acc-item:last-child { border-bottom: none; }

.acc-btn {
  width: 100%;
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 1.5rem;
  text-align: left;
  color: var(--ink);
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.05em;
  transition: background 0.15s;
}

.acc-btn:hover { background: var(--paper2); }
.acc-arrow { font-size: 18px; color: rgba(10, 10, 10, 0.3); transition: transform 0.22s; }
.acc-arrow.open { transform: rotate(45deg); }

.acc-body {
  display: none;
  padding: 0 1.5rem 1.25rem;
  font-size: 13px;
  line-height: 1.75;
  color: rgba(10, 10, 10, 0.6);
  border-top: var(--border-thin);
}

.acc-body.open { display: block; }

.acc-body code {
  font-family: var(--mono);
  font-size: 12px;
  background: var(--paper2);
  padding: 1px 5px;
}

/* ─── ABOUT STRIP ─── */
.about-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: var(--border);
}

@media (max-width: 640px) {
  .about-strip { grid-template-columns: 1fr; }
}

.about-card {
  padding: 2.5rem 2rem;
  border-right: var(--border);
}

.about-card:last-child { border-right: none; }
.about-icon { font-size: 1.5rem; margin-bottom: 1rem; }

.about-h {
  font-family: var(--serif);
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.about-p {
  font-size: 13px;
  color: rgba(10, 10, 10, 0.55);
  line-height: 1.7;
}

/* ─── QUIZ ─── */
.quiz-wrap { border: var(--border); }

.quiz-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: var(--border);
  padding: 1rem 1.5rem;
}

.quiz-score-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.4);
}

.quiz-score-val {
  font-family: var(--serif);
  font-size: 1.6rem;
  font-weight: 700;
}

.quiz-body { padding: 1.75rem 1.5rem; }

.quiz-q {
  font-family: var(--serif);
  font-size: 1.15rem;
  line-height: 1.5;
  margin-bottom: 1.5rem;
}

.quiz-opts {
  display: flex;
  gap: 0;
  flex-wrap: wrap;
  border: var(--border);
}

.quiz-opt {
  flex: 1;
  min-width: 160px;
  background: var(--paper);
  border: none;
  border-right: var(--border);
  padding: 1rem 1.25rem;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  color: var(--ink);
  transition: background 0.15s;
  text-align: center;
}

.quiz-opt:last-child { border-right: none; }
.quiz-opt:hover { background: var(--paper2); }
.quiz-opt.correct { background: #dff3e4; color: #1a5a30; border-color: #3a8a50; }
.quiz-opt.wrong   { background: var(--red-light); color: var(--red); }
.quiz-opt.reveal  { background: #dff3e4; color: #1a5a30; }

.quiz-fb {
  display: none;
  margin-top: 1.25rem;
  padding: 1rem 1.25rem;
  border: 1.5px solid;
  font-size: 13px;
  line-height: 1.75;
}

.quiz-fb.show { display: block; }
.quiz-fb.ok  { border-color: #3a8a50; background: #dff3e4; color: #1a5a30; }
.quiz-fb.bad { border-color: var(--red); background: var(--red-light); color: #7a1515; }

.quiz-next {
  display: none;
  margin-top: 1.25rem;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: none;
  border: var(--border);
  color: var(--ink);
  padding: 10px 22px;
  cursor: pointer;
  transition: background 0.15s;
}

.quiz-next.show { display: inline-block; }
.quiz-next:hover { background: var(--paper2); }

/* ─── FOOTER ─── */
footer {
  border-top: var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 3rem;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.footer-logo {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(10, 10, 10, 0.35);
}

.footer-copy {
  font-family: var(--mono);
  font-size: 10px;
  color: rgba(10, 10, 10, 0.25);
}

/* ─── HERO ENTRY ANIMATIONS ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-left > * { animation: fadeUp 0.6s both; }
.hero-left > :nth-child(1) { animation-delay: 0.05s; }
.hero-left > :nth-child(2) { animation-delay: 0.15s; }
.hero-left > :nth-child(3) { animation-delay: 0.25s; }
.hero-left > :nth-child(4) { animation-delay: 0.35s; }
